#!/bin/bash
# Save a preserved gold-test failure directory as a regression tarball.
# Usage: tests/save-regression <failure-dir> [name]
# If name is omitted, uses the directory's basename.

set -euo pipefail

dir="${1:?usage: $0 <failure-dir> [name]}"
dir="$(cd "$dir" && pwd)"
name="${2:-$(head -c 256 /dev/urandom | tr -dc a-z0-9 | head -c 20)}"

dest="$(cd "$(dirname "$0")/regressions" && pwd)/${name}.tar.gz"
tar czf "$dest" -C "$dir" rcfile $(cd "$dir" && echo msg-*) proc
echo "saved $dest"
